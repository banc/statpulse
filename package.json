{
  "name": "statpulse",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "docker:up": "dotenv -e .env -- docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "db:generate": "dotenv -- npm run db:generate --workspace=@statpulse/database",
    "db:build": "dotenv -- npm run build --workspace=@statpulse/database",
    "db:migrate": "dotenv -- npm run db:migrate --workspace=@statpulse/database",
    "db:studio": "dotenv -- npm run db:studio --workspace=@statpulse/database",
    "worker:dev": "npm run dev --workspace=@statpulse/worker",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev  --workspaces --if-present",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:api": "dotenv -e .env -- npm run dev --workspace=@statpulse/api",
    "dev:worker": "dotenv -e .env -- npm run dev --workspace=@statpulse/worker",
    "test": "npm run test --workspaces --if-present"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
